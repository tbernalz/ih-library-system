{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=IHLibrarySystem;Username=admin;Password=SET_IN_USER_SECRETS;Include Error Detail=true"
  },
  "LibrarySettings": {
    "DailyFineRate": 2.5,
    "DefaultLoanDurationDays": 14
  },
  "AiSettings": {
    "Provider": "openrouter",
    "Model": "google/gemma-4-31b-it:free",
    "ApiKey": "SET_IN_USER_SECRETS",
    "BaseUrl": "https://openrouter.ai/api/v1",
    "MaxTokens": 1000,
    "Temperature": 0.7
  },
  "Discovery": {
    "EmbeddingModel": "openai/text-embedding-3-small",
    "EmbeddingDimensions": 1536,
    "EnableBackgroundIngestion": true,
    "IngestionBatchSize": 8
  },
  "SeedingSettings": {
    "SeededEmailDomain": "@seeded.ihlibrary.local"
  }
}
